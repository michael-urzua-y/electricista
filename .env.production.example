# Django
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=monaysolutions.cl,www.monaysolutions.cl,app.monaysolutions.cl,api.monaysolutions.cl,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://monaysolutions.cl,https://www.monaysolutions.cl,https://app.monaysolutions.cl,https://api.monaysolutions.cl
CORS_ALLOWED_ORIGINS=https://monaysolutions.cl,https://www.monaysolutions.cl,https://app.monaysolutions.cl,https://api.monaysolutions.cl
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER_ENABLED=True

# Base de datos
DB_NAME=monaysolutions
DB_USER=monaysolutions
DB_PASSWORD=cambia-esta-password
DB_HOST=postgres
DB_PORT=5432

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# HTTPS y cookies
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Dominio / certificados
ACME_EMAIL=admin@monaysolutions.cl
DEFAULT_FROM_EMAIL=noreply@monaysolutions.cl
VITE_API_URL=/api
GUNICORN_WORKERS=3

# Mistral AI
MISTRAL_API_KEY=sk-...

# Sentry opcional
SENTRY_DSN=

# Email SMTP opcional
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Tesseract OCR en Linux
TESSERACT_CMD=/usr/bin/tesseract

# Configuracion de negocio
IVA_RATE=0.19
PPM_RATE=0.01
TAX_CUTOFF_WITHOUT_GUIDE_DAY=5
TAX_CUTOFF_WITH_GUIDE_DAY=10
TAX_ESTIMATOR_ACCOUNTANT_FEE=127500
TAX_ESTIMATOR_RENTA_AT_YEAR=2026
TAX_ESTIMATOR_RENTA_AT_MONTH=4
TAX_ESTIMATOR_RENTA_AT_AMOUNT=300000
HONORARIOS_RETENTION_RATES=2024:0.1375,2025:0.1450,2026:0.1525,2027:0.1600
WORKER_UTM_VALUE=67294
WORKER_HEALTH_RATE=7.00
WORKER_UNEMPLOYMENT_RATE=0.60

# Paginacion y archivos
API_DEFAULT_PAGE_SIZE=10
API_MAX_PAGE_SIZE=100
ACCOUNTING_PAGE_SIZE=50
LOW_STOCK_PAGE_SIZE=50
MAX_COMPANY_LOGO_MB=2
MAX_INVOICE_UPLOAD_MB=10
MAX_EXPENSE_UPLOAD_MB=10

# Frontend
VITE_DEFAULT_PAGE_SIZE=10
