# Tesseract OCR (ruta en Mac)
TESSERACT_CMD=/opt/homebrew/bin/tesseract
# En Linux: /usr/bin/tesseract
# En Windows: C:\Program Files\Tesseract-OCR\tesseract.exe

# Demo user password (solo desarrollo)
