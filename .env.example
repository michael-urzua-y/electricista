# Django
SECRET_KEY=tu-clave-secreta-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,monaysolutions.cl,www.monaysolutions.cl

# Database
DB_NAME=electricista
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Mistral AI (para parseo de facturas)
MISTRAL_API_KEY=sk-...

# Sentry (error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email (opcional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@monaysolutions.cl

# Tesseract OCR (ruta en Mac)
TESSERACT_CMD=/opt/homebrew/bin/tesseract
# En Linux: /usr/bin/tesseract
# En Windows: C:\Program Files\Tesseract-OCR\tesseract.exe

# Demo user password (solo desarrollo)
DEMO_PASSWORD=demo123

# CORS (frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://monaysolutions.cl

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Seguridad (producción)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
