{
	email {$ACME_EMAIL}
}

(monay_security) {
	encode zstd gzip
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}

monaysolutions.cl, www.monaysolutions.cl, app.monaysolutions.cl {
	import monay_security

	handle_path /media/* {
		root * /srv/media
		file_server
	}

	handle_path /static/* {
		root * /srv/static
		file_server
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /admin* {
		reverse_proxy backend:8000
	}

	root * /srv/frontend
	try_files {path} /index.html
	file_server
}

api.monaysolutions.cl {
	import monay_security

	handle_path /media/* {
		root * /srv/media
		file_server
	}

	handle_path /static/* {
		root * /srv/static
		file_server
	}

	reverse_proxy backend:8000
}
